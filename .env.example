# GitHub access — fine-grained PAT with contents:read+write on the vault repo
GITHUB_TOKEN=ghp_xxx

# Vault repo location
VAULT_OWNER=your-github-username-or-org
VAULT_REPO=Vault
VAULT_BRANCH=main

# Bearer token clients send to authenticate to this MCP. Generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=replace-me

# Optional: commit author for vault writes (defaults to authenticated GitHub user)
COMMIT_AUTHOR_NAME=
COMMIT_AUTHOR_EMAIL=
